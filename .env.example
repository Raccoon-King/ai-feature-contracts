# Grabby Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Add .env to your .gitignore!

# =============================================================================
# AI Provider API Keys
# =============================================================================

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# Azure OpenAI - https://portal.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=...

# =============================================================================
# AWS Bedrock Configuration
# =============================================================================

# Option 1: Explicit credentials (for local development)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=...  # Optional, for temporary credentials

# Option 2: Use AWS CLI profile (set in grabby.config.json)
# aws configure --profile grabby
# Then set: "profile": "grabby" in config

# Option 3: IAM Role (for EC2/Lambda/ECS)
# No env vars needed - uses instance metadata

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# =============================================================================
# Jira Integration
# =============================================================================

# Jira API Token - https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=...

# For Jira Server/Data Center with Personal Access Tokens
JIRA_PAT=...

# =============================================================================
# Optional: Grabby Settings
# =============================================================================

# Strict mode - block commits without approved contracts
GRABBY_STRICT=0

# Debug mode - verbose logging
GRABBY_DEBUG=0

# Custom contracts directory
GRABBY_CONTRACTS_DIR=contracts

# Disable telemetry
GRABBY_NO_TELEMETRY=1
