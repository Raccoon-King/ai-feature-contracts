{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-feature-contracts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "docs"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "grabbyai.com/*", "zone_name": "grabbyai.com" },
    { "pattern": "www.grabbyai.com/*", "zone_name": "grabbyai.com" }
  ]
}
