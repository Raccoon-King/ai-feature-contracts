#!/bin/sh
#
# Grabby Pre-Push Hook
# Enforces repo-local branch/release strategy:
#
#   feature/* -> development  (squash merge via PR)
#   development -> release tag (semver bump via release workflow)
#   release tag -> main updated (via release PR)
#
# Rules:
# - No direct pushes to main (use release workflow or GRABBY_RELEASE=1)
# - No direct pushes to development (use feature branch PRs or GRABBY_RELEASE=1)
# - Release tags are cut from development
# - Release tags require docs+website audit artifact
#
# Install: grabby init-hooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

is_release_tag_push=0
is_main_branch_push=0
is_dev_branch_push=0
release_tags=""

while read local_ref local_sha remote_ref remote_sha
do
  case "$remote_ref" in
    refs/heads/main)
      is_main_branch_push=1
      ;;
    refs/heads/development)
      is_dev_branch_push=1
      ;;
    refs/tags/*)
      is_release_tag_push=1
      tag_name=$(echo "$remote_ref" | sed 's#refs/tags/##')
      release_tags="$release_tags $tag_name"
      ;;
  esac
done

# Rule 1: direct push to main requires release intent
if [ "$is_main_branch_push" -eq 1 ] && [ "$GRABBY_RELEASE" != "1" ]; then
  echo "${RED}[grabby] Direct push to main blocked.${NC}"
  echo "Workflow: feature/* -> development -> release tag -> main"
  echo ""
  echo "To merge a release to main, use the release workflow or:"
  echo "  GRABBY_RELEASE=1 git push origin main"
  exit 1
fi

# Rule 2: direct push to development requires release intent
# (feature work arrives via squash-merged PRs from feature branches)
if [ "$is_dev_branch_push" -eq 1 ] && [ "$GRABBY_RELEASE" != "1" ]; then
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  # Allow if pushing development branch itself (not a feature branch)
  if [ "$current_branch" != "development" ]; then
    echo "${RED}[grabby] Direct push to development from '${current_branch}' blocked.${NC}"
    echo "Open a PR from your feature branch into development instead."
    exit 1
  fi
  echo "${YELLOW}[grabby] Warning: direct push to development.${NC}"
  echo "Preferred workflow: open a PR from your feature branch."
fi

# Rule 3: release tags must be cut from development (or main for hotfixes)
if [ "$is_release_tag_push" -eq 1 ]; then
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  if [ "$current_branch" != "development" ] && [ "$current_branch" != "main" ]; then
    echo "${RED}[grabby] Release tag blocked.${NC}"
    echo "Release tags must be created from 'development' (or 'main' for hotfixes)."
    echo "Current branch: ${current_branch}"
    exit 1
  fi

  if [ ! -d "contracts" ]; then
    echo "${RED}[grabby] Release tag blocked: contracts/ directory not found.${NC}"
    echo "Run from repository root with contracts present."
    exit 1
  fi

  ACTIVE_CONTRACTS=$(ls contracts/*.fc.md 2>/dev/null)
  if [ -n "$ACTIVE_CONTRACTS" ]; then
    echo "${RED}[grabby] Release tag blocked.${NC}"
    echo "contracts/ must be empty before tagging a release."
    echo "Archive/close all active contracts first."
    echo ""
    echo "Remaining contracts:"
    echo "$ACTIVE_CONTRACTS" | while read contract; do
      [ -n "$contract" ] && echo "  - $contract"
    done
    exit 1
  fi

  echo "${GREEN}[grabby] Release tag gate passed: from ${current_branch}, contracts/ is empty.${NC}"

  # Rule 4: require tag-specific documentation/website audit artifact
  for tag in $release_tags; do
    audit_file="docs/user-guide/release-audits/${tag}.md"
    if [ ! -f "$audit_file" ]; then
      echo "${RED}[grabby] Release tag blocked.${NC}"
      echo "Missing required audit artifact: ${audit_file}"
      echo "Rule: each release tag must include a docs+website audit review file."
      exit 1
    fi
    if ! grep -q "Docs Reviewed: yes" "$audit_file" || ! grep -q "Website Updated: yes" "$audit_file"; then
      echo "${RED}[grabby] Release tag blocked.${NC}"
      echo "Audit file is incomplete: ${audit_file}"
      echo "Required lines:"
      echo "  Docs Reviewed: yes"
      echo "  Website Updated: yes"
      exit 1
    fi
    echo "${GREEN}[grabby] Audit gate passed for tag ${tag}:${NC} ${audit_file}"
  done
fi

exit 0
