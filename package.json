{
  "name": "grabby",
  "version": "4.1.4",
  "description": "Token-efficient feature contract system for AI-assisted development",
  "main": "bin/index.cjs",
  "bin": {
    "grabby": "bin/index.cjs",
    "afc": "bin/index.cjs"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "docs/",
    "agents/",
    "workflows/",
    "hooks/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "bundleDependencies": [
    "chokidar",
    "cli-progress",
    "compression",
    "cors",
    "express",
    "express-rate-limit",
    "express-validator",
    "helmet",
    "swagger-jsdoc",
    "swagger-ui-express",
    "winston",
    "yaml"
  ],
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":80,\"branches\":80,\"functions\":80}}'",
    "lint": "echo 'No lint configured yet'",
    "grabby:init": "node bin/index.cjs init",
    "grabby:validate": "node bin/index.cjs validate",
    "grabby:plan": "node bin/index.cjs plan",
    "grabby:execute": "node bin/index.cjs execute",
    "grabby:guard": "node bin/index.cjs guard",
    "grabby:session": "node bin/index.cjs session --check-all --allow-empty",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "keywords": [
    "ai",
    "cline",
    "claude",
    "feature-contracts",
    "development",
    "automation"
  ],
  "author": "jesse",
  "license": "MIT",
  "homepage": "https://grabbyai-com.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Raccoon-King/ai-feature-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/Raccoon-King/ai-feature-contracts/issues"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "cli-progress": "^3.12.0",
    "compression": "^1.8.1",
    "cors": "2.8.x",
    "express": "^5.2.1",
    "express-rate-limit": "7.1.x",
    "express-validator": "7.0.x",
    "helmet": "7.1.x",
    "swagger-jsdoc": "6.2.x",
    "swagger-ui-express": "5.0.x",
    "winston": "3.11.x",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nock": "13.5.x",
    "supertest": "6.3.x",
    "wrangler": "^4.73.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.cjs",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 67,
        "functions": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "undici": "^7.24.0"
  }
}
