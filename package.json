{
  "name": "grabby",
  "version": "1.0.0",
  "description": "Token-efficient feature contract system for AI-assisted development",
  "main": "bin/index.cjs",
  "bin": {
    "grabby": "bin/index.cjs"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":80,\"branches\":80,\"functions\":80}}'",
    "lint": "node scripts/lint.cjs"
  },
  "keywords": [
    "ai",
    "cline",
    "claude",
    "feature-contracts",
    "development",
    "automation"
  ],
  "author": "jesse",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.cjs",
      "!lib/interactive-workflows.cjs",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 70,
        "functions": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

