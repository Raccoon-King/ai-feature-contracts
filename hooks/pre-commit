#!/bin/sh
#
# Grabby Pre-Commit Hook
# Enforces contract-based development workflow
#
# Install: grabby init-hooks
# Or manually: cp hooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Check if contracts directory exists
if [ ! -d "contracts" ]; then
  echo "${YELLOW}[grabby] No contracts directory found. Run 'grabby init' first.${NC}"
  exit 0
fi

# Get list of staged files (excluding contracts themselves)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|py|go|rs|java|cjs|mjs)$' | grep -v '^contracts/')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Count staged implementation files
STAGED_COUNT=$(echo "$STAGED_FILES" | wc -l)

# Check for active/approved contracts
APPROVED_CONTRACTS=$(ls contracts/*.fc.md 2>/dev/null | while read contract; do
  if grep -q '**Status:** approved\|**Status:** executing' "$contract" 2>/dev/null; then
    echo "$contract"
  fi
done)

ACTIVE_COUNT=$(echo "$APPROVED_CONTRACTS" | grep -c '.' || echo "0")

echo ""
echo "${CYAN}[grabby] Contract Enforcement Check${NC}"
echo "─────────────────────────────────────"
echo "  Staged files: $STAGED_COUNT"
echo "  Active contracts: $ACTIVE_COUNT"
echo ""

# If no active contracts and significant changes, warn
if [ "$ACTIVE_COUNT" -eq "0" ] && [ "$STAGED_COUNT" -gt "0" ]; then
  echo "${YELLOW}⚠ WARNING: No approved contract found for these changes.${NC}"
  echo ""
  echo "  You are committing code without an approved contract."
  echo "  Consider creating a contract first:"
  echo ""
  echo "    ${CYAN}grabby task 'describe your change'${NC}"
  echo "    ${CYAN}grabby agent architect CC${NC}"
  echo ""

  # Check if GRABBY_STRICT mode is enabled
  if [ "$GRABBY_STRICT" = "1" ]; then
    echo "${RED}✗ GRABBY_STRICT mode is enabled. Commit blocked.${NC}"
    echo "  Set GRABBY_STRICT=0 to allow commits without contracts."
    echo ""
    exit 1
  fi

  echo "${YELLOW}Proceeding anyway... (set GRABBY_STRICT=1 to block)${NC}"
  echo ""
fi

# If we have active contracts, show which ones cover the changes
if [ "$ACTIVE_COUNT" -gt "0" ]; then
  echo "${GREEN}✓ Active contracts found:${NC}"
  echo "$APPROVED_CONTRACTS" | while read contract; do
    if [ -n "$contract" ]; then
      NAME=$(basename "$contract" .fc.md)
      echo "  - $NAME"

      # Display pre-op summary if available
      PREOP_FILE=".grabby/pre-ops/${NAME}.preop.txt"
      if [ -f "$PREOP_FILE" ]; then
        echo ""
        echo "${CYAN}Pre-Op Summary:${NC}"
        cat "$PREOP_FILE"
        echo ""
      fi
    fi
  done
  echo ""

  # Validate contracts are still valid
  for contract in $APPROVED_CONTRACTS; do
    if [ -n "$contract" ]; then
      # Run quick validation
      if command -v grabby &> /dev/null; then
        VALIDATION=$(grabby validate "$contract" 2>&1 || true)
        if echo "$VALIDATION" | grep -q "Validation failed"; then
          echo "${YELLOW}⚠ Contract has validation errors: $(basename $contract)${NC}"
        fi
      fi
    fi
  done
fi

# Check for security-sensitive files
SECURITY_FILES=$(echo "$STAGED_FILES" | grep -iE 'auth|login|password|token|secret|credential|payment|crypto' || true)

if [ -n "$SECURITY_FILES" ]; then
  echo "${YELLOW}⚠ Security-sensitive files detected:${NC}"
  echo "$SECURITY_FILES" | while read file; do
    echo "  - $file"
  done
  echo ""
  echo "  Ensure your contract includes a Security Considerations section."
  echo ""
fi

# Run npm audit if package changes
PACKAGE_CHANGES=$(git diff --cached --name-only | grep -E 'package(-lock)?\.json' || true)

if [ -n "$PACKAGE_CHANGES" ]; then
  echo "${CYAN}[grabby] Dependency changes detected, running npm audit...${NC}"

  if command -v npm &> /dev/null; then
    AUDIT_RESULT=$(npm audit --audit-level=high 2>&1 || true)

    if echo "$AUDIT_RESULT" | grep -q "found [1-9]"; then
      echo "${YELLOW}⚠ npm audit found vulnerabilities:${NC}"
      echo "$AUDIT_RESULT" | head -20
      echo ""

      if [ "$GRABBY_STRICT" = "1" ]; then
        echo "${RED}✗ Fix vulnerabilities before committing.${NC}"
        exit 1
      fi
    else
      echo "${GREEN}✓ No high/critical vulnerabilities found.${NC}"
    fi
  fi
  echo ""
fi

echo "${GREEN}✓ Pre-commit checks passed.${NC}"
echo ""

exit 0
