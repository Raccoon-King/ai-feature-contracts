{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://grabby.dev/schemas/manifest.json",
  "title": "Grabby Central Ruleset Manifest",
  "description": "Schema for central ruleset repository manifest.yaml",
  "type": "object",
  "required": ["version", "lastUpdated", "categories"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the manifest schema"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "categories": {
      "type": "object",
      "description": "Category definitions containing rulesets",
      "additionalProperties": {
        "$ref": "#/definitions/category"
      }
    },
    "presets": {
      "type": "object",
      "description": "Pre-composed ruleset bundles",
      "additionalProperties": {
        "$ref": "#/definitions/preset"
      }
    }
  },
  "definitions": {
    "category": {
      "type": "object",
      "required": ["description", "rulesets"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the category"
        },
        "extensible": {
          "type": "boolean",
          "description": "Whether projects can add custom rulesets to this category",
          "default": false
        },
        "rulesets": {
          "type": "array",
          "description": "Rulesets in this category",
          "items": {
            "$ref": "#/definitions/ruleset"
          }
        }
      }
    },
    "ruleset": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Ruleset identifier (lowercase, alphanumeric, hyphens)"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of the ruleset"
        },
        "tags": {
          "type": "array",
          "description": "Tags for filtering and discovery",
          "items": {
            "type": "string"
          }
        },
        "extends": {
          "type": "array",
          "description": "References to parent rulesets (category/name format)",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
          }
        },
        "compatibleWith": {
          "type": "array",
          "description": "Compatible ruleset references",
          "items": {
            "type": "string"
          }
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this ruleset is deprecated",
          "default": false
        }
      }
    },
    "preset": {
      "type": "object",
      "required": ["description", "includes"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the preset"
        },
        "includes": {
          "type": "array",
          "description": "Ruleset references included in this preset",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
          },
          "minItems": 1
        },
        "tags": {
          "type": "array",
          "description": "Tags for filtering and discovery",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
