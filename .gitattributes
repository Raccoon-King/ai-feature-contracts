# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.js      text eol=lf
*.cjs     text eol=lf
*.mjs     text eol=lf
*.ts      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.env     text eol=lf
*.example text eol=lf

# Binary files — do not modify
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.tar.gz  binary

# Diff hints
*.md      diff=markdown
*.cjs     diff=javascript
*.js      diff=javascript
*.ts      diff=javascript
